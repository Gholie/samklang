<ui:FluentWindow x:Class="Samklang.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:local="clr-namespace:Samklang"
                 Title="Samklang"
                 Width="680" Height="720"
                 MinWidth="520" MinHeight="480"
                 WindowStartupLocation="CenterScreen"
                 ExtendsContentIntoTitleBar="True"
                 WindowCornerPreference="Round"
                 Loaded="Window_Loaded"
                 Closing="Window_Closing"
                 Closed="Window_Closed">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <local:ArtworkImageConverter x:Key="ArtworkToImage" />
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Issue #39: FluentWindow draws no native chrome, so without this TitleBar the window
             had no close/minimize buttons and no draggable caption area. It also supplies the
             snap-layout / maximize behavior; the close button routes through Window_Closing and
             therefore keeps the hide-to-tray behavior. Title tracks Window.Title, which carries
             the version suffix set in the constructor. -->
        <ui:TitleBar Grid.Row="0"
                     Title="{Binding Title, RelativeSource={RelativeSource AncestorType=Window}}" />

    <TabControl Grid.Row="1" Margin="16">
        <!-- Now-playing panel + recent-switch history (issue #9). The now-playing presentation
             has two modes behind Settings.RichNowPlaying: a rich hero card (album artwork,
             transport controls, playing animation — NowPlayingViewModel) or a plain text line,
             for users who want a very simple UI. Everything below the now-playing area (stats,
             warnings, history) is shared by both modes. -->
        <TabItem Header="Dashboard">
            <Grid Margin="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Rich now-playing hero card. -->
                <Border Grid.Row="0"
                        DataContext="{Binding NowPlaying}"
                        Visibility="{Binding IsRichView, Converter={StaticResource BoolToVis}}"
                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Album artwork, with a music-note placeholder that shows through
                             whenever there is no artwork to paint over it. -->
                        <Border Grid.Column="0" Grid.RowSpan="2"
                                Width="108" Height="108" Margin="0,0,16,0"
                                VerticalAlignment="Center">
                            <Grid>
                                <Border CornerRadius="6" Background="{DynamicResource ControlFillColorSecondaryBrush}">
                                    <ui:SymbolIcon Symbol="MusicNote224" FontSize="42"
                                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                                </Border>
                                <Border CornerRadius="6">
                                    <Border.Background>
                                        <ImageBrush ImageSource="{Binding ArtworkBytes, Converter={StaticResource ArtworkToImage}}"
                                                    Stretch="UniformToFill" />
                                    </Border.Background>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- Track text + tier badge. -->
                        <StackPanel Grid.Column="1" Grid.Row="0" VerticalAlignment="Center" Margin="0,0,12,8">
                            <TextBlock Text="{Binding Title}" FontSize="20" FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding Artist}" FontSize="14"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       TextTrimming="CharacterEllipsis" Margin="0,2,0,0" />
                            <TextBlock Text="{Binding Album}" FontSize="12"
                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                       TextTrimming="CharacterEllipsis" Margin="0,2,0,0" />
                            <Border Background="{DynamicResource AccentFillColorDefaultBrush}"
                                    CornerRadius="10" Padding="10,3" Margin="0,8,0,0" HorizontalAlignment="Left">
                                <TextBlock Text="{Binding DataContext.Dashboard.AudioTierDisplay, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                           Foreground="{DynamicResource TextOnAccentFillColorPrimaryBrush}"
                                           FontSize="12" FontWeight="Medium" />
                            </Border>
                        </StackPanel>

                        <!-- Transport controls (SMTC previous / play-pause / next). -->
                        <StackPanel Grid.Column="1" Grid.Row="1" Orientation="Horizontal">
                            <ui:Button Icon="{ui:SymbolIcon Previous24}" Command="{Binding PreviousCommand}"
                                       IsEnabled="{Binding HasTrack}" ToolTip="Previous track"
                                       Width="40" Height="40" CornerRadius="20" Padding="0" />
                            <ui:Button Command="{Binding PlayPauseCommand}" Appearance="Primary"
                                       IsEnabled="{Binding HasTrack}" ToolTip="Play / pause"
                                       Width="48" Height="48" CornerRadius="24" Padding="0" Margin="10,0">
                                <ui:SymbolIcon FontSize="20">
                                    <ui:SymbolIcon.Style>
                                        <Style TargetType="ui:SymbolIcon">
                                            <Setter Property="Symbol" Value="Play24" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsPlaying}" Value="True">
                                                    <Setter Property="Symbol" Value="Pause24" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ui:SymbolIcon.Style>
                                </ui:SymbolIcon>
                            </ui:Button>
                            <ui:Button Icon="{ui:SymbolIcon Next24}" Command="{Binding NextCommand}"
                                       IsEnabled="{Binding HasTrack}" ToolTip="Next track"
                                       Width="40" Height="40" CornerRadius="20" Padding="0" />
                        </StackPanel>

                        <!-- Equalizer-style playing animation: five accent bars that bounce while
                             IsPlaying and settle low when idle. Purely decorative — the staggered
                             durations are what make them look independent. Each bar carries its
                             own inline ScaleTransform (not a style setter): WPF freezes Freezables
                             shared through style setters, and a frozen transform can't be
                             animated. -->
                        <StackPanel Grid.Column="2" Grid.RowSpan="2" Orientation="Horizontal"
                                    VerticalAlignment="Center" Margin="8,0,4,0">
                            <StackPanel.Resources>
                                <Style TargetType="Rectangle">
                                    <Setter Property="Width" Value="5" />
                                    <Setter Property="Height" Value="36" />
                                    <Setter Property="RadiusX" Value="2.5" />
                                    <Setter Property="RadiusY" Value="2.5" />
                                    <Setter Property="Margin" Value="2.5,0" />
                                    <Setter Property="VerticalAlignment" Value="Bottom" />
                                    <Setter Property="Fill" Value="{DynamicResource AccentFillColorDefaultBrush}" />
                                    <Setter Property="RenderTransformOrigin" Value="0.5,1" />
                                </Style>
                            </StackPanel.Resources>
                            <Rectangle>
                                <Rectangle.RenderTransform>
                                    <ScaleTransform ScaleY="0.25" />
                                </Rectangle.RenderTransform>
                                <Rectangle.Style>
                                    <Style TargetType="Rectangle" BasedOn="{StaticResource {x:Type Rectangle}}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsPlaying}" Value="True">
                                                <DataTrigger.EnterActions>
                                                    <BeginStoryboard Name="EqBar1">
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                                             From="0.2" To="1.0" Duration="0:0:0.62"
                                                                             AutoReverse="True" RepeatBehavior="Forever" />
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </DataTrigger.EnterActions>
                                                <DataTrigger.ExitActions>
                                                    <StopStoryboard BeginStoryboardName="EqBar1" />
                                                </DataTrigger.ExitActions>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Rectangle.Style>
                            </Rectangle>
                            <Rectangle>
                                <Rectangle.RenderTransform>
                                    <ScaleTransform ScaleY="0.25" />
                                </Rectangle.RenderTransform>
                                <Rectangle.Style>
                                    <Style TargetType="Rectangle" BasedOn="{StaticResource {x:Type Rectangle}}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsPlaying}" Value="True">
                                                <DataTrigger.EnterActions>
                                                    <BeginStoryboard Name="EqBar2">
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                                             From="0.55" To="0.9" Duration="0:0:0.48"
                                                                             AutoReverse="True" RepeatBehavior="Forever" />
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </DataTrigger.EnterActions>
                                                <DataTrigger.ExitActions>
                                                    <StopStoryboard BeginStoryboardName="EqBar2" />
                                                </DataTrigger.ExitActions>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Rectangle.Style>
                            </Rectangle>
                            <Rectangle>
                                <Rectangle.RenderTransform>
                                    <ScaleTransform ScaleY="0.25" />
                                </Rectangle.RenderTransform>
                                <Rectangle.Style>
                                    <Style TargetType="Rectangle" BasedOn="{StaticResource {x:Type Rectangle}}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsPlaying}" Value="True">
                                                <DataTrigger.EnterActions>
                                                    <BeginStoryboard Name="EqBar3">
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                                             From="0.15" To="0.95" Duration="0:0:0.74"
                                                                             AutoReverse="True" RepeatBehavior="Forever" />
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </DataTrigger.EnterActions>
                                                <DataTrigger.ExitActions>
                                                    <StopStoryboard BeginStoryboardName="EqBar3" />
                                                </DataTrigger.ExitActions>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Rectangle.Style>
                            </Rectangle>
                            <Rectangle>
                                <Rectangle.RenderTransform>
                                    <ScaleTransform ScaleY="0.25" />
                                </Rectangle.RenderTransform>
                                <Rectangle.Style>
                                    <Style TargetType="Rectangle" BasedOn="{StaticResource {x:Type Rectangle}}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsPlaying}" Value="True">
                                                <DataTrigger.EnterActions>
                                                    <BeginStoryboard Name="EqBar4">
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                                             From="0.45" To="1.0" Duration="0:0:0.55"
                                                                             AutoReverse="True" RepeatBehavior="Forever" />
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </DataTrigger.EnterActions>
                                                <DataTrigger.ExitActions>
                                                    <StopStoryboard BeginStoryboardName="EqBar4" />
                                                </DataTrigger.ExitActions>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Rectangle.Style>
                            </Rectangle>
                            <Rectangle>
                                <Rectangle.RenderTransform>
                                    <ScaleTransform ScaleY="0.25" />
                                </Rectangle.RenderTransform>
                                <Rectangle.Style>
                                    <Style TargetType="Rectangle" BasedOn="{StaticResource {x:Type Rectangle}}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsPlaying}" Value="True">
                                                <DataTrigger.EnterActions>
                                                    <BeginStoryboard Name="EqBar5">
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                                             From="0.3" To="0.85" Duration="0:0:0.68"
                                                                             AutoReverse="True" RepeatBehavior="Forever" />
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </DataTrigger.EnterActions>
                                                <DataTrigger.ExitActions>
                                                    <StopStoryboard BeginStoryboardName="EqBar5" />
                                                </DataTrigger.ExitActions>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Rectangle.Style>
                            </Rectangle>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Simple now-playing line — the pre-toggle presentation, for users who turned
                     the rich card off in Settings. -->
                <StackPanel Grid.Row="1" Margin="0,0,0,12"
                            Visibility="{Binding NowPlaying.IsSimpleView, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Text="Track: " FontWeight="Bold" />
                        <TextBlock Text="{Binding Dashboard.TrackDisplay}" TextWrapping="Wrap" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Audio Tier: " FontWeight="Bold" VerticalAlignment="Center" />
                        <Border Background="{DynamicResource AccentFillColorDefaultBrush}" CornerRadius="10" Padding="10,2">
                            <TextBlock Text="{Binding Dashboard.AudioTierDisplay}"
                                       Foreground="{DynamicResource TextOnAccentFillColorPrimaryBrush}" FontSize="12" />
                        </Border>
                    </StackPanel>
                </StackPanel>

                <!-- Format stats, shared by both modes. -->
                <Border Grid.Row="2"
                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="16,12" Margin="0,0,0,12">
                    <WrapPanel>
                        <StackPanel Margin="0,0,32,0">
                            <TextBlock Text="Target format" FontSize="11"
                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                            <TextBlock Text="{Binding Dashboard.TargetFormatDisplay}"
                                       FontSize="14" FontWeight="SemiBold" Margin="0,2,0,0" />
                        </StackPanel>
                        <StackPanel Margin="0,0,32,0">
                            <TextBlock Text="Device format" FontSize="11"
                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                            <TextBlock Text="{Binding Dashboard.DeviceFormatDisplay}"
                                       FontSize="14" FontWeight="SemiBold" Margin="0,2,0,0" />
                        </StackPanel>
                        <StackPanel Margin="0,0,32,0">
                            <TextBlock Text="Confidence" FontSize="11"
                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                <TextBlock Text="{Binding Dashboard.ConfidenceDisplay}" FontSize="14" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding Dashboard.SourceLayerDisplay}" FontSize="14"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="6,0,0,0" />
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Visibility="{Binding Dashboard.HasClampedFormat, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="Clamped to" FontSize="11"
                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                            <TextBlock Text="{Binding Dashboard.ClampedFormatDisplay}" FontSize="14"
                                       FontWeight="SemiBold" Foreground="DarkOrange"
                                       TextWrapping="Wrap" Margin="0,2,0,0" />
                        </StackPanel>
                    </WrapPanel>
                </Border>

                <ui:InfoBar Grid.Row="3" Severity="Warning" IsClosable="False" Margin="0,0,0,12"
                            IsOpen="{Binding Dashboard.HasDeviceTargetWarning, Mode=OneWay}"
                            Message="{Binding Dashboard.DeviceTargetWarningMessage}" />

                <ui:InfoBar Grid.Row="4" Severity="Informational" IsClosable="False" Margin="0,0,0,12"
                            IsOpen="{Binding Dashboard.IsPaused, Mode=OneWay}"
                            Title="Switching paused"
                            Message="Formats won't change until you resume from the tray menu." />

                <!-- Apple-Music-style tabs beneath the now-playing area: "Playing Next" (the
                     current album's tracks, fed by the catalog layer's prefetch — no extra
                     lookups) and "History" (the recent-switches log). Both are always live under
                     the hood now; SelectedTabIndex just remembers which one the user is looking
                     at (seeded from Settings' "Show switch log" on first load, then purely
                     user-driven — see DashboardViewModel.SelectedTabIndex). -->
                <TabControl Grid.Row="5" Padding="0" Margin="0,4,0,0"
                            SelectedIndex="{Binding Dashboard.SelectedTabIndex, Mode=TwoWay}">
                    <TabItem Header="Playing Next">
                        <Grid Margin="0,12,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="{Binding Dashboard.AlbumTracksHeader}"
                                       FontWeight="SemiBold" Margin="0,0,0,8" />

                            <Grid Grid.Row="1">
                                <!-- Apple-Music-style track rows: a shared album-artwork thumbnail (every
                                     row is from the same album, so one ArtworkBytes binding covers them
                                     all), title/artist stacked in the middle, duration at the trailing
                                     edge. Cards with a hover highlight over a GridView table so it reads
                                     like a track list, not a grid. -->
                                <ListView ItemsSource="{Binding Dashboard.AlbumTracks}" BorderThickness="0"
                                          Background="Transparent"
                                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                          Visibility="{Binding Dashboard.HasAlbumTracks, Converter={StaticResource BoolToVis}}">
                                    <!-- Clicking a row plays that track (Dashboard.PlayAlbumTrackCommand),
                                         wired via local:ItemClickBehavior since ListViewItem (unlike
                                         ButtonBase) has no built-in Command. CommandParameter is
                                         {Binding} — the row's own AlbumTrackEntry, which is this
                                         ListViewItem's DataContext; the command itself lives up on
                                         Dashboard, reached the same RelativeSource-to-Window way the
                                         hero card's tier badge above does. -->
                                    <ListView.ItemContainerStyle>
                                        <Style TargetType="ListViewItem">
                                            <Setter Property="Padding" Value="0" />
                                            <Setter Property="Margin" Value="0,0,0,2" />
                                            <Setter Property="Background" Value="Transparent" />
                                            <Setter Property="BorderThickness" Value="0" />
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                            <Setter Property="Cursor" Value="Hand" />
                                            <Setter Property="local:ItemClickBehavior.Command"
                                                    Value="{Binding DataContext.Dashboard.PlayAlbumTrackCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}" />
                                            <Setter Property="local:ItemClickBehavior.CommandParameter" Value="{Binding}" />
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ListViewItem">
                                                        <Border x:Name="RowBorder" Background="{TemplateBinding Background}"
                                                                CornerRadius="6" Padding="8,6">
                                                            <ContentPresenter />
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="RowBorder" Property="Background"
                                                                        Value="{DynamicResource ControlFillColorSecondaryBrush}" />
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ListView.ItemContainerStyle>
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <!-- Track number, de-emphasized — the artwork and title carry the row. -->
                                                <TextBlock Grid.Column="0" Text="{Binding Number}" FontSize="12"
                                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                           Width="20" TextAlignment="Right" VerticalAlignment="Center"
                                                           Margin="0,0,10,0" />

                                                <!-- Album artwork thumbnail, mirroring the hero card's placeholder-under-image
                                                     approach: a music-note tile shows through until ArtworkBytes decodes. -->
                                                <Border Grid.Column="1" Width="40" Height="40" Margin="0,0,12,0"
                                                        VerticalAlignment="Center">
                                                    <Grid>
                                                        <Border CornerRadius="4" Background="{DynamicResource ControlFillColorSecondaryBrush}">
                                                            <ui:SymbolIcon Symbol="MusicNote224" FontSize="16"
                                                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                                                        </Border>
                                                        <Border CornerRadius="4">
                                                            <Border.Background>
                                                                <ImageBrush Stretch="UniformToFill"
                                                                            ImageSource="{Binding DataContext.NowPlaying.ArtworkBytes, RelativeSource={RelativeSource AncestorType={x:Type Window}}, Converter={StaticResource ArtworkToImage}}" />
                                                            </Border.Background>
                                                        </Border>
                                                    </Grid>
                                                </Border>

                                                <!-- Title (accented + bold while playing) with artist beneath. -->
                                                <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="0,0,12,0">
                                                    <TextBlock Text="{Binding Title}" FontSize="16" FontWeight="SemiBold"
                                                               TextTrimming="CharacterEllipsis">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <!-- Default Foreground is a Setter here, not a local value on the
                                                                     element above: WPF dependency-property precedence puts local
                                                                     values above style triggers, so a local Foreground would
                                                                     permanently beat the IsCurrent trigger below and the accent
                                                                     highlight would never actually render for the playing row. -->
                                                                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                                                        <Setter Property="Foreground" Value="{DynamicResource AccentTextFillColorPrimaryBrush}" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <TextBlock Text="{Binding Artist}" FontSize="12"
                                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                               TextTrimming="CharacterEllipsis" Margin="0,2,0,0" />
                                                </StackPanel>

                                                <!-- Duration, trailing edge — blank rather than "0:00" when the catalog
                                                     entry (or an older test fake) carries no duration. -->
                                                <TextBlock Grid.Column="3" Text="{Binding DurationDisplay}" FontSize="12"
                                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                           VerticalAlignment="Center" />

                                                <!-- Per-row queue actions (Play Next / Play Last), driving the Apple Music
                                                     app's own context-menu items via Dashboard's commands. Only shown when
                                                     the user has opted into controlling the app (Dashboard.IsAppControlEnabled);
                                                     hidden entirely otherwise, since queuing only works by driving the app.
                                                     When shown, space is reserved always (a hover-driven Opacity, not
                                                     Visibility) so revealing them doesn't jog the row's layout; they fade in
                                                     when the row is hovered. Their own click is handled by the buttons, and
                                                     ItemClickBehavior also ignores row clicks originating on a button, so
                                                     neither also plays the row. Commands (and the visibility flag) live on
                                                     Dashboard, reached the same RelativeSource-to-Window way the row-click
                                                     command is. -->
                                                <StackPanel Grid.Column="4" Orientation="Horizontal"
                                                            VerticalAlignment="Center" Margin="12,0,0,0"
                                                            Visibility="{Binding DataContext.Dashboard.IsAppControlEnabled, RelativeSource={RelativeSource AncestorType={x:Type Window}}, Converter={StaticResource BoolToVis}}">
                                                    <StackPanel.Style>
                                                        <Style TargetType="StackPanel">
                                                            <Setter Property="Opacity" Value="0" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType={x:Type ListViewItem}}}" Value="True">
                                                                    <Setter Property="Opacity" Value="1" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </StackPanel.Style>
                                                    <ui:Button Icon="{ui:SymbolIcon ArrowNext24}" ToolTip="Play Next"
                                                               Command="{Binding DataContext.Dashboard.PlayTrackNextCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                                               CommandParameter="{Binding}"
                                                               Width="32" Height="32" CornerRadius="16" Padding="0" />
                                                    <ui:Button Icon="{ui:SymbolIcon TextBulletListSquare24}" ToolTip="Play Last"
                                                               Command="{Binding DataContext.Dashboard.PlayTrackLastCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                                               CommandParameter="{Binding}"
                                                               Width="32" Height="32" CornerRadius="16" Padding="0" Margin="6,0,0,0" />
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                                <TextBlock Text="Album tracks appear here once the playing track gets a catalog match."
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="4,4,0,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Dashboard.HasAlbumTracks}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Grid>
                    </TabItem>

                    <TabItem Header="History">
                        <ListView Margin="0,12,0,0" ItemsSource="{Binding Dashboard.History}" BorderThickness="0">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Time" DisplayMemberBinding="{Binding TimestampDisplay}" Width="70" />
                                    <GridViewColumn Header="Track" DisplayMemberBinding="{Binding TrackDisplay}" Width="200" />
                                    <GridViewColumn Header="Target format" DisplayMemberBinding="{Binding TargetFormatDisplay}" Width="110" />
                                    <GridViewColumn Header="Audio Tier" DisplayMemberBinding="{Binding AudioTierDisplay}" Width="100" />
                                    <GridViewColumn Header="Confidence" DisplayMemberBinding="{Binding ConfidenceDisplay}" Width="90" />
                                    <GridViewColumn Header="Source layer" DisplayMemberBinding="{Binding SourceLayer}" Width="100" />
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </TabItem>
                </TabControl>
            </Grid>
        </TabItem>

        <!-- Settings: device targeting, tier mappings, Resting Format, Grace Period, autostart (issue #9). -->
        <TabItem Header="Settings">
            <ScrollViewer DataContext="{Binding Settings}" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="16">
                    <TextBlock Text="Resting Format" FontWeight="Bold" Margin="0,0,0,8" />
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <TextBlock Text="Sample rate (Hz):" Width="160" VerticalAlignment="Center" />
                        <TextBox Text="{Binding RestingSampleRateHzText, UpdateSourceTrigger=PropertyChanged}" Width="90" />
                        <TextBlock Text="Bit depth:" VerticalAlignment="Center" Margin="16,0,8,0" />
                        <TextBox Text="{Binding RestingBitDepthText, UpdateSourceTrigger=PropertyChanged}" Width="50" />
                    </StackPanel>

                    <TextBlock Text="Grace Period" FontWeight="Bold" Margin="0,0,0,8" />
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <TextBlock Text="Seconds idle before reverting:" Width="220" VerticalAlignment="Center" />
                        <TextBox Text="{Binding GracePeriodSecondsText, UpdateSourceTrigger=PropertyChanged}" Width="90" />
                    </StackPanel>

                    <TextBlock Text="Device targeting" FontWeight="Bold" Margin="0,0,0,8" />
                    <StackPanel Margin="0,0,0,16">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <RadioButton GroupName="DeviceTargeting" Content="Follow Windows default"
                                         IsChecked="{Binding IsFollowDefaultMode}" VerticalAlignment="Center" Margin="0,0,16,0" />
                            <RadioButton GroupName="DeviceTargeting" Content="Pin a specific device"
                                         IsChecked="{Binding IsPinnedMode}" VerticalAlignment="Center" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <ComboBox Width="280"
                                      ItemsSource="{Binding AvailableDevices}"
                                      DisplayMemberPath="FriendlyName"
                                      SelectedValuePath="Id"
                                      SelectedValue="{Binding SelectedDeviceId}" />
                            <Button Content="Refresh" Padding="8,2" Margin="8,0,0,0" Command="{Binding RefreshDevicesCommand}" />
                        </StackPanel>
                    </StackPanel>

                    <TextBlock Text="Format switching" FontWeight="Bold" Margin="0,0,0,8" />
                    <StackPanel Margin="0,0,0,16">
                        <!-- A single mutually-exclusive choice rather than two independent checkboxes
                             (mute vs. don't, pause vs. don't), because pausing playback while also asking
                             not to mute would be a no-op combination — nothing is being fed to the device
                             once playback is paused — which would be confusing to expose as two separate
                             toggles. Applies immediately (no Save needed), like the other toggles. -->
                        <RadioButton GroupName="FormatSwitchBehavior" Content="Mute through the switch (default)"
                                     IsChecked="{Binding IsMuteThroughSwitchMode}" />
                        <TextBlock Text="Samklang mutes the device right before switching the sample rate and unmutes it right after, so you get a brief silent gap instead of Windows' mute/rebuild hiccup."
                                   FontSize="12" Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                   TextWrapping="Wrap" Margin="28,2,0,8" />
                        <RadioButton GroupName="FormatSwitchBehavior" Content="Pause playback during the switch"
                                     IsChecked="{Binding IsPauseDuringSwitchMode}" />
                        <TextBlock Text="Samklang pauses Apple Music right before switching the sample rate and resumes it right after, instead of just muting through the hiccup. A pause/resume cycle is itself a momentary, audible interruption, so this isn't a universal upgrade over the default."
                                   FontSize="12" Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                   TextWrapping="Wrap" Margin="28,2,0,8" />
                        <RadioButton GroupName="FormatSwitchBehavior" Content="Keep feeding audio (skip mute)"
                                     IsChecked="{Binding IsKeepFeedingAudioDuringSwitchMode}" />
                        <TextBlock Text="Samklang no longer mutes the device around a format switch, so you'll hear Windows' brief hiccup instead of a silent gap."
                                   FontSize="12" Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                   TextWrapping="Wrap" Margin="28,2,0,0" />
                    </StackPanel>

                    <TextBlock Text="Tier mappings — sample rate (Hz) per Audio Tier" FontWeight="Bold" Margin="0,0,0,8" />
                    <StackPanel Margin="0,0,0,16">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Text="Lossy Stereo:" Width="160" VerticalAlignment="Center" />
                            <TextBox Text="{Binding LossyStereoHzText, UpdateSourceTrigger=PropertyChanged}" Width="90" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Text="Lossless:" Width="160" VerticalAlignment="Center" />
                            <TextBox Text="{Binding LosslessHzText, UpdateSourceTrigger=PropertyChanged}" Width="90" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Text="Hi-Res Lossless:" Width="160" VerticalAlignment="Center" />
                            <TextBox Text="{Binding HiResLosslessHzText, UpdateSourceTrigger=PropertyChanged}" Width="90" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Dolby Atmos:" Width="160" VerticalAlignment="Center" />
                            <TextBox Text="{Binding DolbyAtmosHzText, UpdateSourceTrigger=PropertyChanged}" Width="90" />
                        </StackPanel>
                    </StackPanel>

                    <TextBlock Text="Playback" FontWeight="Bold" Margin="0,0,0,8" />
                    <StackPanel Margin="0,0,0,16">
                        <!-- Applies immediately (no Save needed), like the other toggles. Off by default —
                             this is intrusive (it takes over the Apple Music app), so it's opt-in. -->
                        <CheckBox Content="Play songs from the album list (experimental)"
                                  IsChecked="{Binding ControlAppleMusicAppEnabled}" />
                        <TextBlock Text="When on, Samklang briefly takes over the Apple Music app to play a song (or add it with Play Next / Play Last), so the app pops to the front for a moment. When off, clicking a song just opens its album so you can press play yourself."
                                   FontSize="12" Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                   TextWrapping="Wrap" Margin="28,2,0,0" />
                    </StackPanel>

                    <TextBlock Text="Now Playing" FontWeight="Bold" Margin="0,0,0,8" />
                    <StackPanel Margin="0,0,0,16">
                        <!-- Applies immediately (no Save needed), like Start with Windows. -->
                        <CheckBox Content="Rich now-playing view (album artwork, playback controls, animation)"
                                  IsChecked="{Binding RichNowPlayingEnabled}" />
                        <TextBlock Text="Turn off for a simple text-only dashboard."
                                   FontSize="12" Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                   TextWrapping="Wrap" Margin="28,2,0,0" />
                    </StackPanel>

                    <TextBlock Text="Dashboard" FontWeight="Bold" Margin="0,0,0,8" />
                    <StackPanel Margin="0,0,0,16">
                        <!-- Persists immediately (no Save needed), like the rich now-playing toggle, but has no
                             effect on the dashboard until the next launch — both tabs are always reachable, this
                             only picks which one is selected on startup. -->
                        <CheckBox Content="Open on the History tab by default"
                                  IsChecked="{Binding ShowSwitchLogEnabled}" />
                        <TextBlock Text="The dashboard opens on Playing Next by default; turn this on to open on History (recent format switches) instead. You can switch tabs anytime either way — this only sets the starting tab."
                                   FontSize="12" Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                   TextWrapping="Wrap" Margin="28,2,0,0" />
                    </StackPanel>

                    <TextBlock Text="Logging" FontWeight="Bold" Margin="0,0,0,8" />
                    <StackPanel Margin="0,0,0,16">
                        <!-- Applies immediately (no Save needed), like the other toggles above. Off by default. -->
                        <CheckBox Content="Enable detailed logging"
                                  IsChecked="{Binding EnableDetailedLoggingEnabled}" />
                        <TextBlock Text="Warnings and errors are always written to a log file, even with this off. Turn this on to also capture step-by-step detail for debugging."
                                   FontSize="12" Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                   TextWrapping="Wrap" Margin="28,2,0,0" />
                    </StackPanel>

                    <TextBlock Text="Startup" FontWeight="Bold" Margin="0,0,0,8" />
                    <StackPanel Margin="0,0,0,16">
                        <StackPanel Orientation="Horizontal">
                            <CheckBox Content="Start with Windows" IsChecked="{Binding StartWithWindows}" VerticalAlignment="Center" />
                        </StackPanel>
                        <!-- Applies immediately (no Save needed), like the other toggles, though it only
                             takes effect on the next launch. -->
                        <CheckBox Content="Start minimized to tray" IsChecked="{Binding StartMinimizedEnabled}"
                                  Margin="0,8,0,0" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal">
                        <Button Content="Save settings" Padding="12,4" Command="{Binding SaveCommand}" />
                        <TextBlock Text="{Binding StatusMessage}" Margin="12,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </TabItem>
    </TabControl>
    </Grid>
</ui:FluentWindow>
