<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows10.0.19041.0</TargetFramework>
    <SupportedOSPlatformVersion>10.0.19041.0</SupportedOSPlatformVersion>
    <UseWPF>true</UseWPF>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>Samklang</RootNamespace>
    <AssemblyName>Samklang</AssemblyName>
  </PropertyGroup>

  <ItemGroup>
    <!-- Core Audio (MMDevice/AudioEndpointVolume) + WaveFormat marshaling for the device
         controller's IPolicyConfig interop. Per docs/PLAN.md's M1 NuGet list. -->
    <PackageReference Include="NAudio" Version="2.2.1" />
  </ItemGroup>

</Project>
